{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": ["*"],
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "domain": "lark",
      "dmPolicy": "open",
      "accounts": {
        "ceo": {
          "appId": "${LARK_CEO_APP_ID}",
          "appSecret": "${LARK_CEO_APP_SECRET}",
          "name": "CEO Bot",
          "domain": "lark"
        },
        "cs": {
          "appId": "${LARK_CS_APP_ID}",
          "appSecret": "${LARK_CS_APP_SECRET}",
          "name": "CS Bot",
          "domain": "lark"
        },
        "coo": {
          "appId": "${LARK_COO_APP_ID}",
          "appSecret": "${LARK_COO_APP_SECRET}",
          "name": "COO Bot",
          "domain": "lark"
        },
        "cmo": {
          "appId": "${LARK_CMO_APP_ID}",
          "appSecret": "${LARK_CMO_APP_SECRET}",
          "name": "CMO Bot",
          "domain": "lark"
        },
        "cco": {
          "appId": "${LARK_CCO_APP_ID}",
          "appSecret": "${LARK_CCO_APP_SECRET}",
          "name": "CCO Bot",
          "domain": "lark"
        }
      }
    }
  },
  "bindings": [
    { "agentId": "ceo", "match": { "channel": "feishu", "accountId": "ceo" } },
    { "agentId": "cs",  "match": { "channel": "feishu", "accountId": "cs" } },
    { "agentId": "coo", "match": { "channel": "feishu", "accountId": "coo" } },
    { "agentId": "cmo", "match": { "channel": "feishu", "accountId": "cmo" } },
    { "agentId": "cco", "match": { "channel": "feishu", "accountId": "cco" } }
  ],
  "agents": {
    "defaults": {
      "model": {
        "primary": "9router/gemini/gemini-2.5-flash",
        "fallbacks": [
          "9router/iflow/qwen3-coder-plus",
          "9router/iflow/qwen3-max",
          "9router/iflow/kimi-k2-0905"
        ]
      },
      "timeoutSeconds": 180,
      "userTimezone": "Asia/Ho_Chi_Minh",
      "timeFormat": "24"
    },
    "list": [
      {
        "id": "ceo",
        "name": "CEO Agent",
        "default": true,
        "workspace": "/root/workspace-ceo",
        "identity": { "name": "CEO Bot", "emoji": "🏛️" },
        "groupChat": {
          "mentionPatterns": ["@CEO", "@ceo", "@CEO Bot"]
        }
      },
      {
        "id": "cs",
        "name": "CS Agent",
        "workspace": "/root/workspace-cs",
        "identity": { "name": "CS Bot", "emoji": "📞" },
        "groupChat": {
          "mentionPatterns": ["@CS", "@cs", "@CS Bot", "@CSKH"]
        }
      },
      {
        "id": "coo",
        "name": "COO Agent",
        "workspace": "/root/workspace-coo",
        "identity": { "name": "COO Bot", "emoji": "📦" },
        "groupChat": {
          "mentionPatterns": ["@COO", "@coo", "@COO Bot", "@VanHanh"]
        }
      },
      {
        "id": "cmo",
        "name": "CMO Agent",
        "workspace": "/root/workspace-cmo",
        "identity": { "name": "CMO Bot", "emoji": "📢" },
        "groupChat": {
          "mentionPatterns": ["@CMO", "@cmo", "@CMO Bot", "@Marketing"]
        }
      },
      {
        "id": "cco",
        "name": "CCO Agent",
        "workspace": "/root/workspace-cco",
        "identity": { "name": "CCO Bot", "emoji": "💬" },
        "groupChat": {
          "mentionPatterns": ["@CCO", "@cco", "@CCO Bot", "@Quality"]
        }
      }
    ]
  },
  "tools": {
    "profile": "full",
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off"
    }
  },
  "models": {
    "providers": {
      "9router": {
        "baseUrl": "http://9router.railway.internal:20128/v1",
        "apiKey": "${NINEROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "iflow/qwen3-coder-plus",
            "name": "Qwen3 Coder Plus (Free via iFlow)"
          },
          {
            "id": "iflow/kimi-k2",
            "name": "Kimi K2 (Free via iFlow)"
          },
          {
            "id": "iflow/deepseek-v3.2",
            "name": "DeepSeek V3.2 (Free via iFlow)"
          },
          {
            "id": "iflow/qwen3-max",
            "name": "Qwen3 Max (Free via iFlow)"
          },
          {
            "id": "gemini/gemini-2.5-flash",
            "name": "Gemini 2.5 Flash (Paid)"
          },
          {
            "id": "gemini/gemini-2.5-pro",
            "name": "Gemini 2.5 Pro (Paid)"
          }
        ]
      },
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "google/gemini-2.5-pro-preview",
            "name": "Gemini 2.5 Pro"
          },
          {
            "id": "anthropic/claude-sonnet-4",
            "name": "Claude Sonnet 4"
          },
          {
            "id": "deepseek/deepseek-r1",
            "name": "DeepSeek R1 (Reasoning)"
          }
        ]
      }
    }
  }
}
