{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "channels": {
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": ["*"]
    },
    "feishu": {
      "enabled": true,
      "domain": "lark",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "open",
      "requireMention": true,
      "streaming": true,
      "blockStreaming": true,
      "typingIndicator": true,
      "resolveSenderNames": true,
      "accounts": {
        "default": {
          "appId": "${LARK_APP_ID}",
          "appSecret": "${LARK_APP_SECRET}",
          "name": "MH Bot",
          "domain": "lark"
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/root/mhos-workspace",
      "model": {
        "primary": "9router/gemini/gemini-2.5-flash"
      },
      "timeoutSeconds": 120,
      "userTimezone": "Asia/Ho_Chi_Minh",
      "timeFormat": "24"
    }
  },
  "tools": {
    "profile": "full",
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off"
    }
  },
  "models": {
    "providers": {
      "9router": {
        "baseUrl": "http://9router.railway.internal:20128/v1",
        "apiKey": "${NINEROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "iflow/qwen3-coder-plus",
            "name": "Qwen3 Coder Plus (Free via iFlow)"
          },
          {
            "id": "iflow/kimi-k2",
            "name": "Kimi K2 (Free via iFlow)"
          },
          {
            "id": "iflow/deepseek-v3.2",
            "name": "DeepSeek V3.2 (Free via iFlow)"
          },
          {
            "id": "iflow/qwen3-max",
            "name": "Qwen3 Max (Free via iFlow)"
          },
          {
            "id": "gemini/gemini-2.5-flash",
            "name": "Gemini 2.5 Flash (Free via Google AI Studio)"
          },
          {
            "id": "gemini/gemini-2.5-pro",
            "name": "Gemini 2.5 Pro (Free tier)"
          }
        ]
      },
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "google/gemini-2.5-pro-preview",
            "name": "Gemini 2.5 Pro"
          },
          {
            "id": "anthropic/claude-sonnet-4",
            "name": "Claude Sonnet 4"
          },
          {
            "id": "deepseek/deepseek-r1",
            "name": "DeepSeek R1 (Reasoning)"
          }
        ]
      }
    }
  }
}
