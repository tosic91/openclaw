{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "channels": {
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/root/mhos-workspace",
      "model": {
        "primary": "9router/iflow/qwen3-coder-plus"
      },
      "userTimezone": "Asia/Ho_Chi_Minh",
      "timeFormat": "24"
    }
  },
  "tools": {
    "profile": "full"
  },
  "models": {
    "providers": {
      "9router": {
        "baseUrl": "http://9router.railway.internal:20128/v1",
        "apiKey": "${NINEROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "iflow/qwen3-coder-plus",
            "name": "Qwen3 Coder Plus (Free via iFlow)"
          },
          {
            "id": "iflow/kimi-k2",
            "name": "Kimi K2 (Free via iFlow)"
          },
          {
            "id": "iflow/deepseek-v3.2-exp",
            "name": "DeepSeek V3.2 Exp (Free via iFlow)"
          }
        ]
      }
    }
  }
}
