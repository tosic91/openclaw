{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "channels": {
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "9router/iflow/glm-4.7"
      }
    }
  },
  "models": {
    "providers": {
      "9router": {
        "baseUrl": "http://9router.railway.internal:20128/v1",
        "apiKey": "${NINEROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "iflow/glm-4.7",
            "name": "GLM 4.7 (Free via iFlow)"
          },
          {
            "id": "iflow/kimi-k2",
            "name": "Kimi K2 (Free via iFlow)"
          },
          {
            "id": "iflow/deepseek-r1",
            "name": "DeepSeek R1 (Free via iFlow)"
          }
        ]
      }
    }
  }
}
